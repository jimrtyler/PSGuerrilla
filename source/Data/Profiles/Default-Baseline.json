{
  "profileId": "default",
  "profileName": "Default Baseline",
  "description": "Standard security baseline suitable for general organizations. Mirrors the hardcoded defaults in Guerrilla core modules.",
  "version": "2.1.0",

  "threatScoring": {
    "weights": {
      "knownAttackerIp": 100,
      "reauthFromCloud": 60,
      "impossibleTravel": 70,
      "riskyAction": 50,
      "riskyActionFromCloud": 30,
      "concurrentSessions": 45,
      "suspiciousCountry": 40,
      "bruteForceAttempt": 20,
      "bruteForceSuccess": 55,
      "userAgentAnomaly": 30,
      "oauthFromCloud": 25,
      "afterHoursLogin": 15,
      "cloudLoginsOnly": 15,
      "newDevice": 10,
      "newDeviceFromCloud": 35,
      "adminPrivilegeEscalation": 60,
      "emailForwardingRule": 45,
      "driveExternalSharing": 25,
      "bulkFileDownload": 40,
      "highRiskOAuthApp": 55,
      "userSuspension": 20,
      "twoSvDisablement": 50,
      "domainWideDelegation": 80,
      "workspaceSettingChange": 35
    },
    "thresholds": {
      "critical": 100,
      "high": 60,
      "medium": 30,
      "low": 1
    }
  },

  "auditScoring": {
    "severityWeights": {
      "Critical": 10,
      "High": 6,
      "Medium": 3,
      "Low": 1,
      "Info": 0
    },
    "warnMultiplier": 0.5,
    "failMultiplier": 1.0
  },

  "guerrillaScore": {
    "componentWeights": {
      "posture": 0.70,
      "coverage": 0.15,
      "trend": 0.15
    },
    "labels": {
      "lowRisk": { "min": 90, "label": "Low Risk", "color": "Sage" },
      "moderateRisk": { "min": 75, "label": "Moderate Risk", "color": "Sage" },
      "elevatedRisk": { "min": 60, "label": "Elevated Risk", "color": "Gold" },
      "highRisk": { "min": 40, "label": "High Risk", "color": "Amber" },
      "severeRisk": { "min": 20, "label": "Severe Risk", "color": "DeepOrange" },
      "criticalRisk": { "min": 0, "label": "Critical Risk", "color": "DarkRed" }
    }
  },

  "surveillance": {
    "bruteForceThreshold": 5,
    "bruteForceWindowMinutes": 15,
    "cloudLoginMinCount": 3,
    "afterHoursStart": 20,
    "afterHoursEnd": 6,
    "businessDays": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "lookbackDays": 30
  },

  "modules": ["GWS", "AD", "Surveillance", "Watchtower"]
}
